# ============================================================
# Orchestra MCP — Environment Template
# Copy to /opt/orchestra/shared/.env and fill in values
# ============================================================

# ── Domain ──
DOMAIN=orchestra-mcp.dev

# ── PostgreSQL (Supabase) ──
POSTGRES_PASSWORD=change-me-to-random-64-chars

# ── Supabase JWT ──
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-random-base64

# ── Supabase Keys ──
# Generate with: npx supabase-key generate --jwt-secret=<JWT_SECRET>
ANON_KEY=
SERVICE_ROLE_KEY=

# ── Laravel ──
# Generate with: php artisan key:generate --show
APP_KEY=

# ── Stripe Billing ──
STRIPE_KEY=pk_live_xxx
STRIPE_SECRET=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── GitHub OAuth (user login) ──
# Create at: https://github.com/settings/applications/new
# Callback URL: https://orchestra-mcp.dev/auth/v1/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Embedding API (for agent memory / RAG) ──
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# ── SMTP (transactional emails) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@orchestra-mcp.dev
MAIL_FROM_NAME=Orchestra MCP

# ── Slack (team notifications, optional) ──
SLACK_BOT_TOKEN=xoxb-xxx

# ── Firebase (push notifications, optional) ──
FCM_SERVICE_ACCOUNT_PATH=
